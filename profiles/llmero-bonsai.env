PROJECT_NAME="llmero-bonsai"
LLAMA_REPO_URL="https://github.com/PrismML-Eng/llama.cpp.git"
LLAMA_BUILD_TARGETS="llama-cli llama-server"
MODEL_ROOT="./models/llmero-bonsai"
RUN_ROOT="./llmero-bonsai"
LLAMA_EXTRA_ARGS="--temp 0.5 --top-p 0.85 --top-k 20 -ngl 99"
LLAMA_MODEL_REPO="prism-ml/Bonsai-8B-gguf"
LLAMA_MODEL_FILE="Bonsai-8B.gguf"
LLAMA_MODEL_MODE="local"
LLAMA_MODEL_PATH="./models/llmero-bonsai/Bonsai-8B.gguf"
LLAMA_SERVER_ALIAS="bonsai-8b"
LLAMA_SERVER_HOST="127.0.0.1"
LLAMA_SERVER_PORT="8081"
LLAMA_CONTEXT_SIZE="4096"
LLAMA_GPU_LAYERS="99"
LLAMA_SERVER_EXTRA_ARGS="--temp 0.5 --top-p 0.85 --top-k 20"
