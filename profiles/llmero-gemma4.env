MODEL_ROOT="./models/llmero-gemma4"
RUN_ROOT="./llmero-gemma4"
LLAMA_MODEL_MODE="local"
LLAMA_MODEL_REPO="ggml-org/gemma-4-E4B-it-GGUF"
